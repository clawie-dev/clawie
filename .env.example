# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# ── LLM credentials (used by the `chat` intent) ────────────────────────────────
# Optional. Either, both, or neither — the chat intent picks the provider from
# its payload (provider: 'anthropic' | 'openai'). The Clawie credential broker
# injects whichever is set into the spawned agent container's env.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Egress isolation (Linux + Outcall) ─────────────────────────────────────────
# Pluggable EgressProvider. Default 'null' = no network isolation; agent
# containers get host-style egress. Set 'outcall' on Linux deployments where
# outcalld is running.
# CLAWIE_EGRESS=null

# Outcall host API socket — only consulted when CLAWIE_EGRESS=outcall.
# OUTCALL_HOST_SOCKET=/run/outcall/host.sock

# Outcall network suffix; the full network name becomes outcall-<suffix>.
# OUTCALL_NETWORK=clawie

# Outcall bridge gateway IP (DNS filter + HTTP proxy).
# OUTCALL_GATEWAY=10.200.0.1

# Set to 1 to bind-mount Clawie's agent shim socket into each container, so
# the agent can call may_i_reach(host) before egress. Off by default.
# OUTCALL_MOUNT_AGENT_SOCKET=
